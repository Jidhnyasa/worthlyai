{
  "version": 2,
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "framework": null,
  "outputDirectory": "dist/public",
  "functions": {
    "api/server.cjs": {
      "maxDuration": 30,
      "memory": 1024,
      "includeFiles": "dist/app.cjs"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/server.cjs" },
    { "source": "/((?!assets|favicon).*)", "destination": "/index.html" }
  ]
}
